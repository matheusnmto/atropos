{
  "name": "atropos-monorepo",
  "version": "0.1.3",
  "private": true,
  "workspaces": [
    "packages/core",
    "packages/app",
    "packages/plugin"
  ],
  "scripts": {
    "start": "npm start --workspace=packages/app",
    "dev": "npm run dev --workspace=packages/app",
    "build:app": "npm run build --workspace=packages/app",
    "build:plugin": "npm run build --workspace=packages/plugin",
    "build": "npm run build:app && npm run build:plugin"
  },
  "devDependencies": {
    "electron": "28.3.3",
    "electron-builder": "26.8.1"
  }
}